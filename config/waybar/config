{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 0,
    "modules-left": ["clock", "battery"],
    "modules-center": ["niri/workspaces"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "tray"],

    "niri/workspaces": {
    "format": "{icon}",
    "hide-empty": true,
    "all-outputs": true,
    "format-icons": {
        "default": "ΎΕΣ" 
    }
},

    "clock": {
        "format": "ΎΑΩ  {:%H:%M:%S  ≤░Δφ  %a %d}",
        "interval": 1
    },

    "battery": {
        "format": "{icon}  {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },

    "network": {
        "format-wifi": "ΎΘτ",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "≤░Ψς"
    },

    "cpu": {
        "format": "ΎΤ╝  {usage}%",
        "interval": 2
    },

    "memory": {
        "format": "ΌΚο  {percentage}%",
        "interval": 2,
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "≤░ζθ",
        "format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    }
}
